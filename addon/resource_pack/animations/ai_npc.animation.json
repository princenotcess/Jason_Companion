{
  "format_version": "1.8.0",
  "animations": {
    "animation.ai_npc.idle": {
      "loop": true,
      "bones": {
        "leftArm": {
          "rotation": [
            "math.sin(query.life_time * 40) * 2",
            0,
            "-2 + math.sin(query.life_time * 40) * 1"
          ]
        },
        "rightArm": {
          "rotation": [
            "math.sin(query.life_time * 40) * 2",
            0,
            "2 - math.sin(query.life_time * 40) * 1"
          ]
        }
      }
    },
    "animation.ai_npc.walk": {
      "loop": true,
      "anim_time_update": "query.modified_distance_moved",
      "bones": {
        "rightLeg": {
          "rotation": [
            "math.sin(query.anim_time * 38.17) * 40",
            0,
            0
          ]
        },
        "leftLeg": {
          "rotation": [
            "-math.sin(query.anim_time * 38.17) * 40",
            0,
            0
          ]
        },
        "rightArm": {
          "rotation": [
            "-math.sin(query.anim_time * 38.17) * 30",
            0,
            "2"
          ]
        },
        "leftArm": {
          "rotation": [
            "math.sin(query.anim_time * 38.17) * 30",
            0,
            "-2"
          ]
        }
      }
    },
    "animation.ai_npc.look_at_target": {
      "loop": true,
      "bones": {
        "head": {
          "rotation": [
            "query.target_x_rotation",
            "query.target_y_rotation",
            0
          ]
        }
      }
    }
  }
}
