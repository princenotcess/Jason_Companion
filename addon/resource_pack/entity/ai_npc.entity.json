{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "ai_npc:humanoid",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/entity/ai_npc"
      },
      "geometry": {
        "default": "geometry.ai_npc"
      },
      "animations": {
        "idle": "animation.ai_npc.idle",
        "walk": "animation.ai_npc.walk",
        "look_at_target": "animation.ai_npc.look_at_target"
      },
      "scripts": {
        "animate": [
          { "walk": "query.modified_move_speed > 0.01" },
          { "idle": "query.modified_move_speed <= 0.01" },
          "look_at_target"
        ]
      },
      "render_controllers": ["controller.render.ai_npc"],
      "spawn_egg": {
        "base_color": "#3B82F6",
        "overlay_color": "#1E3A5F"
      }
    }
  }
}
